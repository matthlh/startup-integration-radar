# Integration Scout — local environment
# Copy to .env and fill in the values you need. All settings have safe defaults
# for local development, so a blank .env still works.

# ── External API calls ─────────────────────────────────────────────────────
# Master kill-switch for all paid/external calls (Exa, Anthropic).
# Keep this false until you're ready to spend money intentionally.
ENABLE_EXTERNAL_API_CALLS=false

# Exa is used ONLY for company discovery. Get a key at https://exa.ai/.
# Required when running: python scripts/radar.py discover "..." --live
EXA_API_KEY=

# Anthropic is optional and only used for the demo-concept generator's LLM path.
# Leave empty to keep deterministic fallbacks.
ANTHROPIC_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────
# Directory holding the seed CSV, local JSON store, and discovery CSV.
# Local default: backend/data. On Railway/Render point this at a mounted
# volume, e.g. /data.
DATA_DIR=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# Local dev only needs the Next.js URL; for hosted, add your Vercel domain too.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Crawler ────────────────────────────────────────────────────────────────
# Identify our crawler. Update the contact email to your own.
USER_AGENT=IntegrationScoutBot/0.3 contact=you@example.com
